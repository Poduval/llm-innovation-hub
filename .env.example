# Copy this file to ".env" and paste your keys (no quotes unless the key contains spaces).
#   cp .env.example .env
#
# Names must match {PROVIDER}_API_KEY for each key in config/APIs.json, unless you set
# "api_key_env" on that provider to use a different variable name.

# NVIDIA NIM — https://build.nvidia.com/explore/discover
NVIDIA_API_KEY=

# Groq — https://console.groq.com/keys
GROQ_API_KEY=

# Mistral — https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=
