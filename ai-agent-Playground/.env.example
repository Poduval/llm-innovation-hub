# Copy to .env in this folder (optional) or rely on the repo-root ../.env for provider keys.
#   cp .env.example .env

# LiteLLM proxy auth — Open WebUI uses this as OPENAI_API_KEY when calling LiteLLM.
LITELLM_MASTER_KEY=sk-litellm-local

# Open WebUI session signing (change for anything beyond local dev).
WEBUI_SECRET_KEY=change-me-in-production

# Pipelines API key (must match Open WebUI's second OPENAI_API_KEYS entry)
PIPELINES_API_KEY=0p3n-w3bu!

# Provider keys (also valid in repo-root .env): NVIDIA_API_KEY, GROQ_API_KEY, MISTRAL_API_KEY
